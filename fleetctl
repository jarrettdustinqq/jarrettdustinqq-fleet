#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage:
  fleetctl install-nix                Install Nix in user mode
  fleetctl bootstrap [repo_url ...]   Create SSH key, clone/update repos
  fleetctl health                     Run local controller health checks
  fleetctl hub-scan                   Scan inventory into Control Hub DB
  fleetctl hub-serve                  Run scan + local Control Hub dashboard
  fleetctl shell                      Enter nix dev shell (requires nix)
EOF
}

cmd="${1:-}"
shift || true

case "$cmd" in
  install-nix)
    exec "$DIR/install_nix.sh" "$@"
    ;;
  bootstrap)
    exec "$DIR/bootstrap.sh" "$@"
    ;;
  health)
    exec "$DIR/healthcheck.sh" "$@"
    ;;
  hub-scan)
    exec python3 "$DIR/ops/control_hub_agent.py" scan "$@"
    ;;
  hub-serve)
    exec python3 "$DIR/ops/control_hub_agent.py" scan-serve "$@"
    ;;
  shell)
    exec nix develop "$DIR" -c "${SHELL:-bash}"
    ;;
  *)
    usage
    exit 1
    ;;
esac
